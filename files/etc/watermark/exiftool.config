# exiftool config for the `watermark` tool — registers the XMP-wm
# namespace used for the idempotency sentinel.
#
# Deployed to /etc/watermark/exiftool.config by play-image-watermarking.yml.
# Every exiftool invocation in /usr/local/bin/watermark passes
# `-config /etc/watermark/exiftool.config` so these tags are recognised.
#
# The namespace URL is an opaque identifier — it does not need to resolve.
#
# Plan: CLAUDE/Plan/00037-image-watermarking-toolkit/PLAN.md (Decision 3)

%Image::ExifTool::UserDefined = (
    'Image::ExifTool::XMP::Main' => {
        wm => {
            SubDirectory => {
                TagTable => 'Image::ExifTool::UserDefined::wm',
            },
        },
    },
);

%Image::ExifTool::UserDefined::wm = (
    GROUPS    => { 0 => 'XMP', 1 => 'XMP-wm', 2 => 'Image' },
    NAMESPACE => { 'wm' => 'https://example.com/ns/watermark/1.0/' },
    WRITABLE  => 'string',
    Applied   => { Writable => 'boolean' },
    AppliedAt => { Writable => 'date' },
    AppliedBy => { },
);

# exiftool config files must end with a truthy Perl value
1;
