#!/usr/bin/env bash
set -e

# ftp-camera — start FTP server for Sony A7V camera uploads
# Deployed by: playbooks/imports/optional/common/play-ftp-camera.yml

# Resolve upload directory from the camera FTP user's home directory
# (set by play-ftp-camera.yml via ftp_camera_upload_dir variable)
UPLOAD_DIR=$(getent passwd camera | cut -d: -f6)
if [ -z "$UPLOAD_DIR" ]; then
    echo "ERROR: 'camera' user not found — run play-ftp-camera.yml first" >&2
    exit 1
fi

MONITOR_PID=""
VSFTPD_LOG_PID=""
VIEWER_MONITOR_PID=""
START_MARKER=$(mktemp)
SORT_ONLY=false
PASS_ONLY=false
PUSH_ONLY=false
COPY_ONLY=false
PRUNE_ONLY=false
ASYNC_MODE=false
ASYNC_COPY_MODE=false
# Viewer modifier: optional live preview of each completed upload in a
# single geeqie window. Composes with default / --async / --async-copy.
# Set by --view (RAW) or --view-jpg (JPG); mutually exclusive.
VIEWER_MODE=false
VIEWER_CLASS=""   # RAW or JPG once set

# Hotspot state — populated by detect_hotspot() once at startup. The
# script then uses these globals to decide which interface IP to
# advertise (get_local_ip), which firewall zone to open the FTP ports
# in, and what to print in the startup banner. All defaults are "no
# hotspot active" so non-hotspot invocations behave exactly as before.
HOTSPOT_ACTIVE=false
HOTSPOT_DEV=""
HOTSPOT_IP=""
HOTSPOT_SSID=""
# Hotspot-modifier flag: when --hotspot is passed, ftp-camera activates
# the NetworkManager profile named ${HOTSPOT_CONNECTION:-Hotspot} at
# startup and deactivates it on exit. HOTSPOT_OWNED_BY_US tracks whether
# we activated it (so cleanup only tears down what we brought up — a
# pre-existing hotspot the user toggled by hand is left alone).
HOTSPOT_FLAG=false
HOTSPOT_OWNED_BY_US=false
# Async stats are tracked in a temp file (append-only — atomic for small
# writes) so the background monitor and cleanup() see a consistent view.
ASYNC_STATS_FILE=""
ASYNC_COPY_FAILED_FILE=""
# Local rclone mount path resolved at --async-copy startup. Files are
# copied here (fast, local) and the rclone VFS handles async upload to
# the remote — the same write-through path --copy uses, but per-file.
ASYNC_MOUNT_PATH=""

# Records repo path for --pass helper (deployed by play-ftp-camera.yml).
readonly CONFIG_FILE="/etc/ftp-camera/config"

# ── Help text ────────────────────────────────────────────────────────────────
show_help() {
    cat <<'EOF'
Usage: ftp-camera [PRIMARY-MODE] [MODIFIER]

Primary modes (pick at most one; default = full FTP server):
  (none)        Start FTP server, sort at end on Ctrl+C
  --async       Run FTP server, sorting each file the moment it arrives
  --async-copy  Run FTP server with instant sort AND per-file copy into
                the local rclone mount (VFS uploads to the remote in the
                background; requires ftp_camera_rclone_remote)
  --sort        Sort already-uploaded files by EXIF date and exit
  --pass        Print the camera FTP password to stdout and exit
  --push        Direct push to rclone remote (reliable, synchronous)
  --copy        Copy via rclone mount (caches locally) then verify on remote
  --prune       Remove RAW files whose corresponding JPG has been deleted

Modifiers (apply to FTP-server modes only; combinable):
  --view        Live single-window preview of each ARW arrival via geeqie
                (geeqie's implicit single-instance handles window-reuse —
                second invocation routes the new file into the running window,
                no IPC).
  --view-jpg    Same, but preview JPG arrivals instead of ARW.
                (--view and --view-jpg are mutually exclusive.)
  --hotspot     Bring up the NetworkManager 'Hotspot' profile (or whichever
                profile HOTSPOT_CONNECTION points to in /etc/ftp-camera/config)
                at start, tear it down on exit. Camera connects directly to
                the laptop — bypasses any public WiFi. Fail-fast if the named
                profile doesn't exist (create one via GNOME Settings → Wi-Fi).
                If the hotspot is already up when ftp-camera starts, the flag
                uses it as-is and leaves it alone on exit.

Launcher:
  Invoked with no arguments, ftp-camera opens a two-step TUI (gum or fzf) to
  pick the primary mode and the viewer option. Pass --no-tui to suppress the
  launcher and run in default FTP-server mode.

  -h, --help    Show this help

When run with --view / --view-jpg the source folder watched depends on the
primary mode:
  --async / --async-copy → photos/$(date +%Y/%m/%d)/{RAW,JPG}/  (sorted tree)
  default (no sort)      → upload root, filtered by extension
The viewer always loads from the LOCAL ftp tree — never the rclone mount
destination. Pre-warm runs only in async modes (default mode may have stale
files in the root we don't want to surface).

Async modes do the same EXIF-based sort the closing pass does, but as soon
as each upload completes — no end-of-session bulk move. Triggering is
gated on vsftpd's "OK UPLOAD" log entry, so partial/aborted transfers
are NEVER sorted or copied; they sit in the upload root for inspection.
--async-copy then copies each sorted file into the local rclone mount
(same write-through path --copy uses) via a tmp-then-rename so a crash
mid-copy can't leave a truncated file masquerading as complete; the VFS
uploads to the remote in the background, so losing rclone progress mid-
session never costs you data — the file lives in the upload tree, the
mount cache, and (eventually) the remote. Crash recovery: rerun
`ftp-camera --push` to ship anything still missing on the remote.

Sort layout (mirrors the photo library):
  photos/YYYY/MM/DD/JPG/<name>.jpg
  photos/YYYY/MM/DD/RAW/<name>.arw
  videos/YYYY/MM/DD/MP4/<name>.mp4
  videos/YYYY/MM/DD/MOV/<name>.mov

ftp_camera_rclone_remote must point at the LIBRARY ROOT (the parent of
photos/ and videos/), not at a media subfolder. Push, copy, and
async-copy ship into the matching subtree on the remote automatically.

Typical workflow:
  1. ftp-camera           # receive uploads from camera (Ctrl+C to stop, auto-sorts)
  2. ftp-camera --copy    # copy via mount + verify (files cached for instant browse)
     OR
  2. ftp-camera --push    # direct push (prints rclone-cache-warm hint after)
  3. (manually delete unwanted JPGs from the upload tree)
  4. ftp-camera --prune   # delete RAW files orphaned by JPG removal (photos/ only)

Async workflow (drop step 2 entirely):
  1. ftp-camera --async-copy   # sort + push each file as it arrives
  2. (manually delete unwanted JPGs from the upload tree)
  3. ftp-camera --prune        # delete RAW files orphaned by JPG removal

Async + live preview:
  ftp-camera --async-copy --view   # rare; only when you want to spot-check
                                   # ARW exposure live as the camera shoots
EOF
}

# ── Launcher TUI ─────────────────────────────────────────────────────────────
# Two-step `gum choose` (or `fzf` fallback) for argument-free invocation.
# Picks primary mode then viewer modifier, then exec-replaces this script
# with the chosen flags. The viewer step is skipped for non-server modes
# (sort/push/copy/prune/pass) which have nothing to view. Default viewer
# selection is "no viewer" — preview is the rare case.
#
# When neither gum nor fzf is installed, the caller skips this function
# and falls through to default FTP-server mode with an info note.
run_launcher_tui() {
    local picker="$1"  # "gum" or "fzf"

    # Server modes (default / async / async-copy) are tagged "[+viewer]"
    # to advertise that picking one of them surfaces the optional viewer
    # picker in step 2. Non-server modes exit immediately and have nothing
    # to view, so they're listed without the tag.
    local mode_lines=(
        "default      [+viewer]  Start FTP server, sort at end on Ctrl+C"
        "async        [+viewer]  Sort each upload as it arrives"
        "async-copy   [+viewer]  Sort + per-file rclone copy as uploads arrive"
        "sort                    Sort already-uploaded files and exit"
        "push                    Direct rclone push of the sort tree and exit"
        "copy                    Mount-write-through copy with verify and exit"
        "prune                   Delete orphan RAW files (interactive) and exit"
        "pass                    Print FTP password and exit"
    )
    local mode_header="Step 1/3 — pick a primary mode  (viewer + hotspot offered next for server modes)"

    local mode_choice
    if [ "$picker" = gum ]; then
        # gum choose returns 130 on Esc/Ctrl-C; the `if !` captures that
        # so we can exit cleanly without a stack trace.
        if ! mode_choice=$(gum choose --header "$mode_header" \
                                      "${mode_lines[@]}"); then
            echo "Cancelled." >&2
            exit 130
        fi
    else
        if ! mode_choice=$(printf '%s\n' "${mode_lines[@]}" \
                | fzf --height 40% --no-info --no-sort \
                      --header "$mode_header"); then
            echo "Cancelled." >&2
            exit 130
        fi
    fi

    # First whitespace-separated token is the canonical mode keyword.
    local mode_keyword
    mode_keyword=$(echo "$mode_choice" | awk '{print $1}')

    local exec_args=()
    case "$mode_keyword" in
        default)  ;;                                # no flag → default mode
        *)        exec_args+=("--${mode_keyword}") ;;
    esac

    # Step 2 — viewer picker, only for FTP-server modes.
    case "$mode_keyword" in
        default | async | async-copy)
            local viewer_lines=(
                "no viewer"
                "view RAW"
                "view JPG"
            )
            local viewer_header="Step 2/3 — viewer?  (rare; usually leave 'no viewer')"
            local viewer_choice
            if [ "$picker" = gum ]; then
                if ! viewer_choice=$(gum choose \
                        --header "$viewer_header" \
                        --selected "no viewer" \
                        "${viewer_lines[@]}"); then
                    echo "Cancelled." >&2
                    exit 130
                fi
            else
                # fzf highlights the first match by default; "no viewer"
                # is line 1, so it's the default-highlighted choice.
                if ! viewer_choice=$(printf '%s\n' "${viewer_lines[@]}" \
                        | fzf --height 20% --no-info --no-sort \
                              --header "$viewer_header"); then
                    echo "Cancelled." >&2
                    exit 130
                fi
            fi
            case "$viewer_choice" in
                "view RAW")  exec_args+=(--view) ;;
                "view JPG")  exec_args+=(--view-jpg) ;;
                # "no viewer" — no flag added
            esac

            # Step 3 — hotspot picker (only for server modes; same predicate
            # as step 2). Default is "no hotspot" because the typical
            # workflow is home-network testing where the hotspot would
            # disconnect the laptop from its existing WiFi unnecessarily.
            local hotspot_lines=("no hotspot" "use hotspot")
            local hotspot_header="Step 3/3 — hotspot?  (skips public WiFi; rare unless on an untrusted network)"
            local hotspot_choice
            if [ "$picker" = gum ]; then
                if ! hotspot_choice=$(gum choose \
                        --header "$hotspot_header" \
                        --selected "no hotspot" \
                        "${hotspot_lines[@]}"); then
                    echo "Cancelled." >&2
                    exit 130
                fi
            else
                if ! hotspot_choice=$(printf '%s\n' "${hotspot_lines[@]}" \
                        | fzf --height 20% --no-info --no-sort \
                              --header "$hotspot_header"); then
                    echo "Cancelled." >&2
                    exit 130
                fi
            fi
            case "$hotspot_choice" in
                "use hotspot") exec_args+=(--hotspot) ;;
            esac
            ;;
    esac

    # If the user picked default + no viewer + no hotspot, exec_args is
    # empty — passing nothing would re-trigger the launcher on entry.
    # --no-tui is a silent opt-out that means "you already went through
    # the picker".
    if [ "${#exec_args[@]}" -eq 0 ]; then
        exec_args=(--no-tui)
    fi

    exec "$0" "${exec_args[@]}"
}

# ── Args ─────────────────────────────────────────────────────────────────────
# At most one primary mode + at most one viewer modifier. Flags compose in
# any order. Invocation with no arguments routes to the launcher TUI.

# Capture "was the script called with zero args" BEFORE the loop consumes
# them. The launcher fires only when the user typed `ftp-camera` bare;
# the launcher exec-replaces, so by the time we re-enter we have args.
NO_ARGS=false
if [ "$#" -eq 0 ]; then
    NO_ARGS=true
fi

# Snapshot of the original args so the systemd-inhibit re-exec further
# below can replay them. The arg loop shifts each one as it consumes them,
# leaving "$@" empty by the end — the old single-case parser never
# shifted so the inhibit wrap could just pass "$@" verbatim; we have to
# preserve them explicitly now.
ORIG_ARGS=("$@")

while [ "$#" -gt 0 ]; do
    case "$1" in
        --sort)        SORT_ONLY=true ;;
        --pass)        PASS_ONLY=true ;;
        --push)        PUSH_ONLY=true ;;
        --copy)        COPY_ONLY=true ;;
        --prune)       PRUNE_ONLY=true ;;
        --async)       ASYNC_MODE=true ;;
        --async-copy)  ASYNC_MODE=true; ASYNC_COPY_MODE=true ;;
        --view)
            if [ "$VIEWER_MODE" = true ]; then
                echo "ERROR: --view and --view-jpg are mutually exclusive" >&2
                exit 2
            fi
            VIEWER_MODE=true
            VIEWER_CLASS=RAW
            ;;
        --view-jpg)
            if [ "$VIEWER_MODE" = true ]; then
                echo "ERROR: --view and --view-jpg are mutually exclusive" >&2
                exit 2
            fi
            VIEWER_MODE=true
            VIEWER_CLASS=JPG
            ;;
        --hotspot)
            HOTSPOT_FLAG=true
            ;;
        --no-tui)
            # Silent: the script entry-point check below uses NO_ARGS to
            # decide whether to route to the launcher; --no-tui presence
            # means $# > 0 so the launcher path is skipped anyway.
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            echo "ERROR: unknown argument: $1" >&2
            echo "Run 'ftp-camera --help' for usage" >&2
            exit 2
            ;;
    esac
    shift
done

# Reject multiple primary modes — those used to be impossible because the
# old parser only looked at $1; the new while loop accepts arbitrary
# combinations so we validate explicitly.
mode_count=0
for _mode in SORT_ONLY PASS_ONLY PUSH_ONLY COPY_ONLY PRUNE_ONLY ASYNC_MODE; do
    if [ "${!_mode}" = true ]; then
        mode_count=$((mode_count + 1))
    fi
done
if [ "$mode_count" -gt 1 ]; then
    echo "ERROR: only one primary mode at a time" >&2
    echo "  Pick one of: --sort --pass --push --copy --prune --async --async-copy" >&2
    exit 2
fi

# Reject viewer with non-server modes — those exit immediately and have
# nothing to view.
if [ "$VIEWER_MODE" = true ]; then
    for _mode in SORT_ONLY PASS_ONLY PUSH_ONLY COPY_ONLY PRUNE_ONLY; do
        if [ "${!_mode}" = true ]; then
            echo "ERROR: --view / --view-jpg requires an FTP-server mode" >&2
            echo "  (default, --async, or --async-copy). The mode you picked" >&2
            echo "  exits before any uploads arrive, so there's nothing to view." >&2
            exit 2
        fi
    done
fi

# Same rejection for --hotspot: a hotspot is only useful while the FTP
# server is up to receive uploads. Tear-down modes (sort/push/copy/...)
# would just bring the hotspot up and immediately back down.
if [ "$HOTSPOT_FLAG" = true ]; then
    for _mode in SORT_ONLY PASS_ONLY PUSH_ONLY COPY_ONLY PRUNE_ONLY; do
        if [ "${!_mode}" = true ]; then
            echo "ERROR: --hotspot requires an FTP-server mode" >&2
            echo "  (default, --async, or --async-copy). The mode you picked" >&2
            echo "  exits without running the FTP server." >&2
            exit 2
        fi
    done
fi

# ── Launcher fallback ────────────────────────────────────────────────────────
# Bare `ftp-camera` invocation: open the TUI to pick mode + viewer. The
# launcher exec-replaces this script, so on return we are guaranteed to
# have flags. If neither TUI tool is installed, print a one-line note and
# proceed with default mode (the safest fallback).
if [ "$NO_ARGS" = true ]; then
    if command -v gum > /dev/null; then
        run_launcher_tui gum
    elif command -v fzf > /dev/null; then
        run_launcher_tui fzf
    else
        echo "Note: neither 'gum' nor 'fzf' is installed — TUI unavailable." >&2
        echo "  Starting default FTP-server mode. Run 'ftp-camera --help'" >&2
        echo "  for the full flag list, or install gum/fzf to get the picker." >&2
    fi
fi

# ── Inhibit suspend during transfers ──────────────────────────────────────────
# Long-running modes (FTP server, --async*, --push, --copy) must keep the
# laptop awake — on battery the session would otherwise idle-suspend and
# break the upload mid-flight. Self-re-exec under systemd-inhibit so logind
# holds an idle+sleep lock for the whole run; GNOME honours both, covering
# idle-timeout AND programmatic suspend. Cheap/interactive modes (anything
# that exits in seconds) skip the wrap. The guard env var prevents an exec
# loop on re-entry.
_skip_inhibit=false
if [ "$PASS_ONLY" = true ] || [ "$SORT_ONLY" = true ] || [ "$PRUNE_ONLY" = true ]; then
    _skip_inhibit=true
fi
if [ "$_skip_inhibit" = false ] \
        && [ -z "${_FTP_CAMERA_INHIBITED:-}" ] \
        && command -v systemd-inhibit > /dev/null; then
    export _FTP_CAMERA_INHIBITED=1
    # Replay ORIG_ARGS, not "$@": the while-loop above shifted "$@" empty
    # while parsing. Passing empty would re-trigger NO_ARGS on the inhibit
    # re-entry and reopen the launcher (the "TUI fires twice" symptom).
    exec systemd-inhibit \
        --what=idle:sleep \
        --who="ftp-camera" \
        --why="Camera FTP transfer in progress" \
        --mode=block \
        -- "$0" "${ORIG_ARGS[@]}"
fi

# ── Colours ───────────────────────────────────────────────────────────────────
BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
NC='\033[0m'

# ── Media taxonomy ────────────────────────────────────────────────────────────
# Mirrors the photo library layout: top-level photos/ and videos/ siblings.
# Sort routes files into the matching subtree based on extension; push/copy
# then ship the whole local tree to the library root in one rclone call,
# landing each subtree in the correctly-named remote folder automatically.
readonly PHOTO_DIR_NAME="photos"
readonly VIDEO_DIR_NAME="videos"
readonly -a PHOTO_EXTS=(jpg jpeg arw)
readonly -a VIDEO_EXTS=(mp4 mov)

# ── Helpers ────────────────────────────────────────────────────────────────────

# Classify a file by extension. Echoes "photo", "video", or "" (unknown).
classify_ext() {
    local ext_lower="${1,,}"
    local e
    for e in "${PHOTO_EXTS[@]}"; do
        if [ "$e" = "$ext_lower" ]; then
            echo photo
            return
        fi
    done
    for e in "${VIDEO_EXTS[@]}"; do
        if [ "$e" = "$ext_lower" ]; then
            echo video
            return
        fi
    done
}

# Read EXIF capture date as YYYY/MM/DD. Photos prefer DateTimeOriginal (the
# shutter-press time), videos prefer CreateDate (the recording-start time).
# Each falls back to the other class's tag in case of unusual files.
get_exif_date() {
    local file="$1" class="$2"
    local -a tags
    if [ "$class" = "photo" ]; then
        tags=(-DateTimeOriginal -CreateDate)
    else
        tags=(-CreateDate -MediaCreateDate)
    fi
    # `|| true`: exiftool exits non-zero when none of the requested tags exist.
    exiftool -s3 -d '%Y/%m/%d' "${tags[@]}" "$file" 2>/dev/null \
        | awk 'NF{print; exit}' || true
}

# Refuse a RCLONE_REMOTE that points at a media subfolder rather than the
# library root. The local sort places files into photos/ and videos/ subtrees
# so a single rclone copy must target the library root for both to land
# correctly. Pointing at .../photos would dump videos/ alongside photos at
# the wrong level — block it with a clear fix.
validate_library_remote() {
    local stripped="${RCLONE_REMOTE%/}"
    case "${stripped,,}" in
        */photos | */photo | */videos | */video)
            echo "ERROR: ftp_camera_rclone_remote must point at the library root," >&2
            echo "  not a photos/videos subdirectory. Got: ${RCLONE_REMOTE}" >&2
            echo "  The local sort places files into ${PHOTO_DIR_NAME}/ and ${VIDEO_DIR_NAME}/" >&2
            echo "  subtrees that mirror the library layout. Update host_vars/localhost.yml:" >&2
            echo "    ftp_camera_rclone_remote: \"${stripped%/*}\"" >&2
            echo "  then re-run play-ftp-camera.yml." >&2
            return 1
            ;;
    esac
}

# Probe NetworkManager for an active connection with ipv4.method=shared
# (a hotspot). When found, populate the HOTSPOT_* globals so subsequent
# code (get_local_ip, firewall-zone handling, banner) can refer to them
# without re-querying nmcli. Call once at script entry; idempotent.
detect_hotspot() {
    command -v nmcli > /dev/null || return 0

    local conn
    conn=$(nmcli -t -f NAME connection show --active 2>/dev/null \
        | while IFS= read -r n; do
              [ -n "$n" ] || continue
              if [ "$(nmcli -g ipv4.method connection show "$n" 2>/dev/null)" = shared ]; then
                  printf '%s' "$n"
                  break
              fi
          done)
    [ -n "$conn" ] || return 0

    local dev ip ssid
    dev=$(nmcli -g GENERAL.DEVICES connection show "$conn" 2>/dev/null)
    [ -n "$dev" ] || return 0
    ip=$(ip -4 addr show dev "$dev" | awk '/inet / {print $2; exit}' | cut -d/ -f1)
    [ -n "$ip" ] || return 0
    # SSID is wireless-only; non-wireless shared connections (rare) leave
    # this empty, which the banner prints as a dash.
    ssid=$(nmcli -g 802-11-wireless.ssid connection show "$conn" 2>/dev/null)

    HOTSPOT_ACTIVE=true
    HOTSPOT_DEV="$dev"
    HOTSPOT_IP="$ip"
    HOTSPOT_SSID="$ssid"
}

get_local_ip() {
    # When a hotspot is active, the laptop's WiFi card is in AP mode and
    # the default route is typically absent (Intel cards can't do
    # concurrent client+AP). Advertise the hotspot IP so the camera —
    # which is on the same 10.x.x.x subnet — can actually reach the FTP
    # server.
    if [ "$HOTSPOT_ACTIVE" = true ]; then
        printf '%s\n' "$HOTSPOT_IP"
        return 0
    fi

    # Otherwise fall back to the default-route interface (the original
    # behaviour for normal LAN/Wi-Fi connectivity).
    local iface
    iface=$(ip -4 route show default | awk '{print $5; exit}')
    if [ -z "$iface" ]; then
        echo "ERROR: No default network interface found AND no hotspot active." >&2
        echo "  Either connect to a network OR turn on a hotspot in GNOME quick" >&2
        echo "  settings (or via 'nmcli device wifi hotspot') and try again." >&2
        exit 1
    fi
    ip -4 addr show dev "$iface" | awk '/inet / {print $2; exit}' | cut -d/ -f1
}

# Sort uploaded files into YYYY/MM/DD/(JPG|RAW)/ based on EXIF DateTimeOriginal
sort_uploads() {
    local dir="${1:-$UPLOAD_DIR}"
    local moved=0 skipped=0

    if [ ! -d "$dir" ]; then
        echo "ERROR: Upload directory not found: $dir" >&2
        return 1
    fi

    if ! command -v exiftool > /dev/null; then
        echo "ERROR: exiftool not found — run play-photography.yml first" >&2
        return 1
    fi

    echo -e "${BOLD}Sorting uploads by EXIF date...${NC}"

    # Build find -iname args from the taxonomy so adding extensions in one
    # place picks them up in both the scan and the routing.
    local -a find_args=()
    local ext
    for ext in "${PHOTO_EXTS[@]}" "${VIDEO_EXTS[@]}"; do
        if [ ${#find_args[@]} -eq 0 ]; then
            find_args+=(-iname "*.$ext")
        else
            find_args+=(-o -iname "*.$ext")
        fi
    done

    # Only process unsorted files in the upload root (where the camera drops them).
    # Already-sorted files live in <class>/YYYY/MM/DD/ subdirs and are never revisited.
    local file
    while IFS= read -r -d '' file; do
        local file_ext="${file##*.}"
        local ext_lower="${file_ext,,}"
        local ext_upper="${file_ext^^}"

        local class
        class=$(classify_ext "$ext_lower")
        if [ -z "$class" ]; then
            echo -e "  ${YELLOW}skip${NC}  $(basename "$file")  (unsupported type)"
            skipped=$((skipped + 1))
            continue
        fi

        # ARW → RAW; everything else keeps its uppercased extension as the type dir
        local type_dir="$ext_upper"
        if [ "$ext_upper" = "ARW" ]; then
            type_dir="RAW"
        fi

        local class_dir
        if [ "$class" = "photo" ]; then
            class_dir="$PHOTO_DIR_NAME"
        else
            class_dir="$VIDEO_DIR_NAME"
        fi

        local date_path
        date_path=$(get_exif_date "$file" "$class")

        if [ -z "$date_path" ]; then
            echo -e "  ${YELLOW}skip${NC}  $(basename "$file")  (no EXIF date)"
            skipped=$((skipped + 1))
            continue
        fi

        local dest_dir="$UPLOAD_DIR/$class_dir/$date_path/$type_dir"
        sudo mkdir -p "$dest_dir"
        sudo mv "$file" "$dest_dir/"
        echo -e "  ${GREEN}move${NC}  $(basename "$file")  → ${class_dir}/${date_path}/${type_dir}/"
        moved=$((moved + 1))
    done < <(find "$dir" -maxdepth 1 -type f \( "${find_args[@]}" \) -print0)

    # Clean up empty directories left behind by camera (e.g. DCIM/100MSDCF/)
    sudo find "$dir" -mindepth 1 -type d -empty -delete 2>/dev/null

    echo ""
    echo -e "${BOLD}Sort complete:${NC} ${CYAN}${moved}${NC} moved, ${CYAN}${skipped}${NC} skipped"
}

# Push the entire sorted upload tree to a configured rclone remote.
# Uses `rclone copy` directly — synchronous, returns a real exit code,
# never goes through a mount's VFS cache. Local copy is preserved; user
# can clean up manually after verifying the remote.
push_uploads() {
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "ERROR: $CONFIG_FILE not found — run play-ftp-camera.yml first" >&2
        return 1
    fi

    # shellcheck source=/dev/null
    . "$CONFIG_FILE"

    if [ -z "${RCLONE_REMOTE:-}" ]; then
        echo "ERROR: RCLONE_REMOTE not set in $CONFIG_FILE" >&2
        echo "  Set ftp_camera_rclone_remote in host_vars/localhost.yml and re-run play-ftp-camera.yml" >&2
        return 1
    fi

    validate_library_remote || return 1

    if ! command -v rclone > /dev/null; then
        echo "ERROR: rclone not found — run play-rclone.yml first" >&2
        return 1
    fi

    if [ ! -d "$UPLOAD_DIR" ]; then
        echo "ERROR: Upload directory not found: $UPLOAD_DIR" >&2
        return 1
    fi

    echo -e "${BOLD}Pushing sorted uploads:${NC}"
    echo -e "  Source: ${CYAN}${UPLOAD_DIR}${NC}"
    echo -e "  Dest:   ${CYAN}${RCLONE_REMOTE}${NC}"
    echo ""

    # --update: skip files that already exist with same size/mtime (re-runnable)
    # --transfers/--checkers: parallelism for Drive's per-file overhead
    rclone copy "$UPLOAD_DIR" "$RCLONE_REMOTE" \
        --progress \
        --transfers 4 \
        --checkers 8 \
        --update

    echo ""
    echo -e "${GREEN}Push complete.${NC}"
    echo -e "${YELLOW}Local copy retained at:${NC} ${CYAN}${UPLOAD_DIR}${NC}"
    echo -e "${YELLOW}Verify on the remote, then remove locally when ready.${NC}"

    # Hint: warm VFS cache so mount browsing doesn't re-download
    local mount_path
    if mount_path=$(find_mount_path 2>/dev/null); then
        echo ""
        echo -e "${BOLD}To browse via mount without re-downloading:${NC}"
        echo -e "  rclone-cache-warm ${CYAN}${mount_path}${NC}"
    fi
}

# Resolve the local mount path corresponding to RCLONE_REMOTE.
# e.g. RCLONE_REMOTE=lts-photo:/PHOTO/LIBRARY/photos with mount lts-photo:/ at ~/mnt/lts-photo
# → returns ~/mnt/lts-photo/PHOTO/LIBRARY/photos
find_mount_path() {
    local remote_name="${RCLONE_REMOTE%%:*}"
    local remote_path="${RCLONE_REMOTE#*:}"

    local mount_target
    mount_target=$(findmnt -n -o TARGET -t fuse.rclone 2>/dev/null \
        | while IFS= read -r mnt; do
            src=$(findmnt -n -o SOURCE "$mnt" 2>/dev/null)
            case "$src" in "${remote_name}:"*) echo "$mnt"; break;; esac
        done)

    if [ -z "$mount_target" ]; then
        echo "ERROR: No rclone mount found for remote '${remote_name}'" >&2
        echo "  Is rclone-${remote_name}.service running?" >&2
        echo "  Start it: systemctl --user start rclone-${remote_name}" >&2
        return 1
    fi

    # Get the mount's source path to calculate the offset under the mount
    local mount_source mount_src_path
    mount_source=$(findmnt -n -o SOURCE "$mount_target" 2>/dev/null)
    mount_src_path="${mount_source#*:}"

    # Strip mount source prefix from remote path
    local rel="${remote_path#"$mount_src_path"}"
    rel="${rel#/}"

    if [ -n "$rel" ]; then
        echo "${mount_target}/${rel}"
    else
        echo "$mount_target"
    fi
}

# Copy sorted uploads to the rclone mount (populates VFS cache for instant
# browsing), wait for async uploads to complete, then verify files reached
# the remote via rclone check. On failure, prints exactly what's missing
# and suggests --push as a fallback.
copy_to_mount() {
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "ERROR: $CONFIG_FILE not found — run play-ftp-camera.yml first" >&2
        return 1
    fi

    # shellcheck source=/dev/null
    . "$CONFIG_FILE"

    if [ -z "${RCLONE_REMOTE:-}" ]; then
        echo "ERROR: RCLONE_REMOTE not set in $CONFIG_FILE" >&2
        echo "  Set ftp_camera_rclone_remote in host_vars/localhost.yml and re-run play-ftp-camera.yml" >&2
        return 1
    fi

    validate_library_remote || return 1

    if ! command -v rclone > /dev/null; then
        echo "ERROR: rclone not found — run play-rclone.yml first" >&2
        return 1
    fi

    if [ ! -d "$UPLOAD_DIR" ]; then
        echo "ERROR: Upload directory not found: $UPLOAD_DIR" >&2
        return 1
    fi

    local dest_path
    dest_path=$(find_mount_path)

    if [ ! -d "$dest_path" ]; then
        echo "ERROR: Mount destination not found: $dest_path" >&2
        echo "  Is the rclone mount active?" >&2
        return 1
    fi

    local rc_addr="localhost:${RCLONE_RC_PORT:-5572}"

    # Verify RC endpoint is reachable before starting the copy
    if ! rclone rc --url="http://${rc_addr}" core/pid > /dev/null 2>&1; then
        echo "ERROR: rclone remote control not responding at ${rc_addr}" >&2
        echo "  Mount may not have --rc enabled — re-run play-rclone.yml" >&2
        return 1
    fi

    local file_count
    file_count=$(find "$UPLOAD_DIR" -type f | wc -l)

    echo -e "${BOLD}Copying to rclone mount:${NC}"
    echo -e "  Source: ${CYAN}${UPLOAD_DIR}${NC}"
    echo -e "  Dest:   ${CYAN}${dest_path}${NC}"
    echo -e "  Files:  ${CYAN}${file_count}${NC}"
    echo ""

    # Reset rclone counters so the displayed bytes/transfers/ETA reflect
    # only this copy, not whatever the mount accumulated since boot.
    rclone rc --url="http://${rc_addr}" core/stats-reset > /dev/null 2>&1 || true

    # Copy files through mount — lands in VFS cache and triggers async upload
    if ! cp -r "$UPLOAD_DIR"/. "$dest_path"/; then
        echo "ERROR: Failed to copy files to mount" >&2
        return 1
    fi
    echo -e "  ${GREEN}${file_count} files copied to mount.${NC}"

    echo ""
    echo -e "${BOLD}Waiting for uploads to complete (Ctrl+C to abort)...${NC}"

    # Give VFS a beat to ingest the freshly-copied files before polling —
    # otherwise the first check can see an empty queue and exit before the
    # writeback has even started.
    sleep 3

    # Poll vfs/stats and core/stats until VFS reports no in-flight or
    # queued uploads for two consecutive checks. No wall-clock timeout —
    # the user can Ctrl+C if they want to bail.
    local wait_start=$SECONDS
    local empty_streak=0
    local prev_bytes=0
    local prev_time=$wait_start

    while true; do
        local vfs_json core_json
        vfs_json=$(rclone rc --url="http://${rc_addr}" vfs/stats 2>/dev/null) || {
            echo "ERROR: Lost connection to rclone RC at ${rc_addr}" >&2
            return 1
        }
        core_json=$(rclone rc --url="http://${rc_addr}" core/stats 2>/dev/null) || {
            echo "ERROR: Lost connection to rclone RC at ${rc_addr}" >&2
            return 1
        }

        # Extract: VFS uploadsInProgress/uploadsQueued/erroredFiles (the
        # authoritative signal for completion when copying through a mount),
        # and core bytes/totalBytes/transfers/totalTransfers/eta for display.
        local metrics
        metrics=$(python3 - "$vfs_json" "$core_json" <<'PY'
import json, sys
vfs = json.loads(sys.argv[1])
core = json.loads(sys.argv[2])

dc = (vfs.get("diskCache") or {})
in_progress = int(dc.get("uploadsInProgress", 0))
queued = int(dc.get("uploadsQueued", 0))
errored = int(dc.get("erroredFiles", 0))

bytes_done = int(core.get("bytes", 0) or 0)
total_bytes = int(core.get("totalBytes", 0) or 0)
done_count = int(core.get("transfers", 0) or 0)
total_count = int(core.get("totalTransfers", 0) or 0)
eta = core.get("eta")
eta_s = "" if eta is None else str(int(eta))

print(f"{in_progress}|{queued}|{errored}|{bytes_done}|{total_bytes}|{done_count}|{total_count}|{eta_s}")
PY
        ) || {
            echo "ERROR: Failed to parse rclone stats" >&2
            return 1
        }

        local in_progress queued errored bytes_done total_bytes done_count total_count eta
        IFS='|' read -r in_progress queued errored bytes_done total_bytes done_count total_count eta <<<"$metrics"

        local now=$SECONDS
        local elapsed=$(( now - wait_start ))
        local elapsed_human
        elapsed_human=$(printf '%dm%02ds' $((elapsed / 60)) $((elapsed % 60)))

        # Completion: 2 consecutive empty checks (avoids exiting during a
        # transient gap between cp finishing and writeback dequeuing).
        if [ "$in_progress" -eq 0 ] && [ "$queued" -eq 0 ]; then
            empty_streak=$(( empty_streak + 1 ))
            if [ "$empty_streak" -ge 2 ]; then
                echo -e "  [${CYAN}${elapsed_human}${NC}] ${GREEN}all uploads complete${NC}"
                if [ "$errored" -gt 0 ]; then
                    echo -e "  ${RED}${errored} file(s) errored during upload — see rclone log${NC}" >&2
                fi
                break
            fi
        else
            empty_streak=0
        fi

        # Instantaneous rate from the bytes delta between this poll and the
        # last one — more useful than core/stats' lifetime average.
        local delta_t=$(( now - prev_time ))
        local rate_bps=0
        if [ "$delta_t" -gt 0 ] && [ "$bytes_done" -ge "$prev_bytes" ]; then
            rate_bps=$(( (bytes_done - prev_bytes) / delta_t ))
        fi
        prev_bytes=$bytes_done
        prev_time=$now

        local rate_human bytes_human total_bytes_human eta_human
        rate_human=$(numfmt --to=iec --suffix=B/s "$rate_bps" 2>/dev/null || echo "—")
        bytes_human=$(numfmt --to=iec --suffix=B "$bytes_done" 2>/dev/null || echo "?")
        total_bytes_human=$(numfmt --to=iec --suffix=B "$total_bytes" 2>/dev/null || echo "?")
        if [ -n "$eta" ] && [ "$eta" != "0" ]; then
            eta_human=$(printf '%dm%02ds' $((eta / 60)) $((eta % 60)))
        else
            eta_human="—"
        fi

        echo -e "  [${CYAN}${elapsed_human}${NC}] queued: ${CYAN}${queued}${NC} · active: ${CYAN}${in_progress}${NC} · done: ${CYAN}${done_count}/${total_count}${NC} (${bytes_human}/${total_bytes_human}) · ${GREEN}${rate_human}${NC} · ETA ${YELLOW}${eta_human}${NC}"
        sleep 5
    done

    echo ""

    # Verify every local file exists on the remote with matching checksum
    echo -e "${BOLD}Verifying files on Drive...${NC}"
    local check_output
    if check_output=$(rclone check "$UPLOAD_DIR" "$RCLONE_REMOTE" --one-way 2>&1); then
        echo -e "${GREEN}All ${file_count} files verified on Drive.${NC}"
        echo -e "Files are cached locally — browsing the mount will be instant."
        echo ""
        echo -e "${YELLOW}Local copy retained at:${NC} ${CYAN}${UPLOAD_DIR}${NC}"
        echo -e "${YELLOW}Verify on the remote, then remove locally when ready.${NC}"
    else
        echo -e "${RED}Verification failed:${NC}" >&2
        echo "$check_output" >&2
        echo "" >&2
        echo -e "${YELLOW}Some files may not have reached Drive.${NC}" >&2
        echo -e "Run ${CYAN}ftp-camera --push${NC} to push remaining files directly." >&2
        return 1
    fi
}

# Remove RAW files whose corresponding JPG has been deleted by the user.
# An "orphan" is a RAW file in photos/YYYY/MM/DD/RAW/ whose stem (basename
# without extension) has no matching .jpg/.jpeg in the sibling JPG/ (or
# JPEG/) directory. Videos have no RAW counterparts so the videos/ subtree
# is skipped. Lists candidates, prompts for confirmation, then deletes.
prune_orphan_raws() {
    local dir="${1:-$UPLOAD_DIR}"
    local photos_root="$dir/$PHOTO_DIR_NAME"

    if [ ! -d "$dir" ]; then
        echo "ERROR: Upload directory not found: $dir" >&2
        return 1
    fi

    if [ ! -d "$photos_root" ]; then
        echo -e "${GREEN}No ${PHOTO_DIR_NAME}/ subtree — nothing to prune.${NC}"
        return 0
    fi

    echo -e "${BOLD}Scanning for orphan RAW files...${NC}"

    local orphans=()
    local raw_dir
    while IFS= read -r -d '' raw_dir; do
        local date_dir="${raw_dir%/RAW}"
        local raw_file
        while IFS= read -r -d '' raw_file; do
            local stem
            stem=$(basename "$raw_file")
            stem="${stem%.*}"

            local found=false
            local sibling
            for sibling in "${date_dir}/JPG" "${date_dir}/JPEG"; do
                [ -d "$sibling" ] || continue
                if find "$sibling" -maxdepth 1 -type f \
                    \( -iname "${stem}.jpg" -o -iname "${stem}.jpeg" \) \
                    -print -quit 2>/dev/null | grep -q .; then
                    found=true
                    break
                fi
            done

            if [ "$found" = false ]; then
                orphans+=("$raw_file")
            fi
        done < <(find "$raw_dir" -maxdepth 1 -type f -iname '*.arw' -print0)
    done < <(find "$photos_root" -type d -name 'RAW' -print0)

    local count=${#orphans[@]}
    if [ "$count" -eq 0 ]; then
        echo -e "${GREEN}No orphan RAW files found.${NC}"
        return 0
    fi

    local total_bytes=0
    local f sz
    for f in "${orphans[@]}"; do
        sz=$(stat -c %s "$f")
        total_bytes=$((total_bytes + sz))
    done
    local total_human
    total_human=$(numfmt --to=iec-i --suffix=B "$total_bytes")

    echo ""
    echo -e "${BOLD}Found ${CYAN}${count}${NC}${BOLD} orphan RAW file(s) (${CYAN}${total_human}${BOLD} total):${NC}"
    for f in "${orphans[@]}"; do
        echo -e "  ${YELLOW}${f#"$UPLOAD_DIR"/}${NC}"
    done

    echo ""
    local reply=""
    read -r -p "Delete these files? [y/N] " reply || true
    if [[ ! "$reply" =~ ^[Yy]$ ]]; then
        echo -e "${YELLOW}Aborted — no files removed.${NC}"
        return 0
    fi

    local removed=0
    for f in "${orphans[@]}"; do
        if sudo rm -f "$f"; then
            removed=$((removed + 1))
        else
            echo -e "  ${RED}failed${NC}  ${f#"$UPLOAD_DIR"/}" >&2
        fi
    done

    # Remove any directories left empty by the prune (RAW/ folders, date dirs)
    sudo find "$dir" -mindepth 1 -type d -empty -delete 2>/dev/null

    echo ""
    echo -e "${BOLD}Prune complete:${NC} ${CYAN}${removed}${NC} of ${CYAN}${count}${NC} files removed (${CYAN}${total_human}${NC} freed)"
}

# ── Async helpers ─────────────────────────────────────────────────────────────
# Source /etc/ftp-camera/config and confirm rclone is usable. Used by the
# async-copy startup path to fail fast before vsftpd is even started.
load_rclone_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        echo "ERROR: $CONFIG_FILE not found — run play-ftp-camera.yml first" >&2
        return 1
    fi

    # shellcheck source=/dev/null
    . "$CONFIG_FILE"

    if [ -z "${RCLONE_REMOTE:-}" ]; then
        echo "ERROR: RCLONE_REMOTE not set in $CONFIG_FILE" >&2
        echo "  Set ftp_camera_rclone_remote in host_vars/localhost.yml and re-run play-ftp-camera.yml" >&2
        return 1
    fi

    validate_library_remote || return 1

    if ! command -v rclone > /dev/null; then
        echo "ERROR: rclone not found — run play-rclone.yml first" >&2
        return 1
    fi
}

# Sort a single file into UPLOAD_DIR/<class>/YYYY/MM/DD/<TYPE>/. Echoes the
# new absolute path on success. Exit codes are meaningful so callers can
# distinguish "skip, retry later" from "give up":
#   0 — moved (new path on stdout)
#   1 — unsupported extension (file unchanged)
#   2 — EXIF date unreadable (file unchanged; a later pass may succeed)
#   3 — filesystem error (file unchanged)
#   4 — file vanished between event fire and handler run (no-op; benign)
sort_one_file() {
    local file="$1"

    # Vanished is its own code: it happens legitimately when the camera
    # retries an upload (the first event's file was already moved by the
    # second event's handler) and isn't an error worth logging loudly.
    [ -f "$file" ] || return 4

    local file_ext="${file##*.}"
    local ext_lower="${file_ext,,}"
    local ext_upper="${file_ext^^}"

    local class
    class=$(classify_ext "$ext_lower")
    [ -n "$class" ] || return 1

    local type_dir="$ext_upper"
    if [ "$ext_upper" = "ARW" ]; then
        type_dir="RAW"
    fi

    local class_dir
    if [ "$class" = "photo" ]; then
        class_dir="$PHOTO_DIR_NAME"
    else
        class_dir="$VIDEO_DIR_NAME"
    fi

    local date_path
    date_path=$(get_exif_date "$file" "$class")
    [ -n "$date_path" ] || return 2

    local dest_dir="$UPLOAD_DIR/$class_dir/$date_path/$type_dir"
    sudo mkdir -p "$dest_dir" || return 3
    sudo mv "$file" "$dest_dir/" || return 3

    echo "$dest_dir/$(basename "$file")"
}

# Copy one already-sorted file into the rclone mount so the VFS cache picks
# it up and async-uploads to the remote. This is the same write-through path
# `--copy` uses, just per-file:
#   - `cp` is fast and local — the script never blocks on network speed.
#   - The file lives in three places (upload tree, VFS cache, eventually
#     remote), so no single failure loses data.
#   - The mount keeps running as a systemd user service after ftp-camera
#     exits, so any cached writes still drain to the remote in the background.
#
# Crash safety: we cp into a `.ftp-camera.tmp.NAME` sibling first, then mv
# to the real name. If the cp is interrupted (Ctrl+C, kill, power loss),
# the partial file is parked under a tmp name that rclone may upload
# verbatim but which never shadows or masquerades as the real file —
# `--push --update` later still sees the real name as missing and re-ships
# it cleanly. Without this, an interrupted cp would leave a truncated
# `foo.jpg` in cache; rclone would upload it; `--push --update` would
# compare size+mtime against that truncated upload and skip the re-ship.
copy_one_file_to_mount() {
    local sorted_file="$1"
    local rel="${sorted_file#"$UPLOAD_DIR"/}"
    local rel_dir
    rel_dir=$(dirname "$rel")
    local basename
    basename=$(basename "$sorted_file")

    local dest_dir="${ASYNC_MOUNT_PATH%/}/${rel_dir}"
    local tmp_path="${dest_dir}/.ftp-camera.tmp.${basename}"
    local final_path="${dest_dir}/${basename}"

    # Mount-disappearance guard. If the rclone FUSE service stops mid-
    # session, the mount path becomes a regular directory on the underlying
    # filesystem; `cp` would succeed but those bytes would never reach the
    # remote. We use `findmnt -T` (which finds the mount CONTAINING the
    # given path, not just exact mount-points — important because
    # ASYNC_MOUNT_PATH is typically a subdirectory inside the mount root,
    # not the mount root itself) filtered to `fuse.rclone`. Match = path
    # is still served by an rclone mount; no match = it isn't.
    if ! findmnt -T "$ASYNC_MOUNT_PATH" -t fuse.rclone --noheadings > /dev/null 2>&1; then
        echo "ERROR: $ASYNC_MOUNT_PATH is no longer served by an rclone mount" >&2
        return 1
    fi

    mkdir -p "$dest_dir" || return 1
    # Plain `cp` (no -p) — rclone FUSE mounts targeting cloud backends like
    # Google Drive cannot represent POSIX mode/ownership, so `cp -p` exits
    # non-zero with "Operation not supported" after the bytes have already
    # streamed through. The original file in the upload tree is untouched.
    if ! cp "$sorted_file" "$tmp_path"; then
        rm -f "$tmp_path"
        return 1
    fi
    if ! mv "$tmp_path" "$final_path"; then
        rm -f "$tmp_path"
        return 1
    fi
}

# Record one outcome in the async stats file. Each call appends a single
# short key — `echo >>` is atomic for writes under PIPE_BUF (4096) so
# concurrent monitors couldn't tear a record, even though today we only
# have one.
_async_stat_inc() {
    [ -n "$ASYNC_STATS_FILE" ] || return 0
    echo "$1" >> "$ASYNC_STATS_FILE"
}

# ── Viewer helpers ───────────────────────────────────────────────────────────

# Return 0 if the file's extension matches the configured VIEWER_CLASS.
# RAW = .arw; JPG = .jpg or .jpeg. Anything else → 1. Used to gate the
# viewer hook so JPG arrivals don't fire when watching RAW (and vice versa).
viewer_class_matches() {
    local file="$1"
    local ext="${file##*.}"
    ext="${ext,,}"
    case "$VIEWER_CLASS" in
        RAW) [ "$ext" = arw ] ;;
        JPG) [ "$ext" = jpg ] || [ "$ext" = jpeg ] ;;
        *)   return 1 ;;
    esac
}

# Open one file in geeqie. Geeqie 2.x is implicitly single-instance via
# its plain CLI — a second invocation routes the file path into the
# already-running window without any --remote flag or socket plumbing.
# Backgrounded so the existing-instance handshake doesn't block the
# vsftpd-log monitor loop on its way to handling the next upload.
#
# Prints a visible "view" event line on the user's terminal so the
# user can see the hook firing; geeqie's stdout/stderr stays muted to
# avoid GTK warning spam in the upload stream.
# Open one file in geeqie. Uses --file=, which is geeqie 2.x's documented
# remote-control entry point: layout_set_path() + gtk_window_present() on the
# existing primary (geeqie is single-instance via GApplication / session D-Bus).
#
# Why `setsid -f` instead of `&`:
#   The naive `geeqie "$file" &` form is called from inside a tail|awk|while
#   pipeline (default mode) or an inotifywait subshell (async modes). When the
#   backgrounded invocation inherits a stale or missing DBUS_SESSION_BUS_ADDRESS
#   it falls back to G_APPLICATION_NON_UNIQUE and silently spawns a new primary
#   instead of routing to the user-visible window — manifesting as "view log
#   line fires but the window never switches". `setsid -f` fully detaches into
#   its own session/PGID, removing the pipeline-attachment failure mode, and
#   returns 0 from the parent once the fork completes.
#
# `GQ_NEW_INSTANCE=` defensively clears the env var geeqie reads to force
# non-unique mode; an accidental inheritance breaks single-instance routing.
display_in_viewer() {
    local file="$1"
    local ts
    ts=$(date '+%H:%M:%S')
    echo -e "  [${CYAN}${ts}${NC}] ${GREEN}view${NC}  $(basename "$file")  → geeqie"
    GQ_NEW_INSTANCE= setsid -f geeqie --file="$file" > /dev/null 2>&1
}

# Background loop for the viewer in default (non-sort) mode. Tails the
# vsftpd OK UPLOAD log (same authoritative signal --async modes use, so
# partial transfers never fire the viewer), filters on VIEWER_CLASS, and
# pushes each matching file's absolute path through display_in_viewer.
# Runs ALONGSIDE the existing default-mode inotifywait pretty-printer —
# the inotify loop is for human-readable upload notifications, this
# loop is for the geeqie hook.
viewer_monitor_loop() {
    sudo tail -F -n 0 --pid=$$ /var/log/vsftpd.log 2>/dev/null \
        | awk -F'"' '/OK UPLOAD: Client/ {print $4; fflush()}' \
        | while IFS= read -r fname; do
            [ -n "$fname" ] || continue
            local abs="${UPLOAD_DIR}/${fname#/}"
            if viewer_class_matches "$abs"; then
                display_in_viewer "$abs"
            fi
          done
}

# Structured human-friendly summary of the runtime configuration. Printed
# once just before the script enters its monitor loop, so the user can
# verify at a glance which combination of flags is actually active —
# important now that --view / --view-jpg compose with three different
# primary modes and the watched folder / pre-warm behaviour depends on
# the combination. Field set is conditional: rclone/mount rows only
# appear when async-copy is configured; viewer/watching/pre-warm rows
# only appear when VIEWER_MODE=true.
print_startup_banner() {
    local mode_desc watch_path prewarm_desc

    if [ "$ASYNC_COPY_MODE" = true ]; then
        mode_desc="async-copy (sort + per-file rclone copy)"
    elif [ "$ASYNC_MODE" = true ]; then
        mode_desc="async (sort each upload on arrival)"
    else
        mode_desc="default (collect now; sort at Ctrl+C)"
    fi

    if [ "$VIEWER_MODE" = true ]; then
        if [ "$ASYNC_MODE" = true ]; then
            watch_path="${UPLOAD_DIR}/${PHOTO_DIR_NAME}/$(date +%Y/%m/%d)/${VIEWER_CLASS}/"
            prewarm_desc="yes (geeqie opened against the watch folder)"
        else
            watch_path="${UPLOAD_DIR}/  (upload root; ${VIEWER_CLASS} arrivals only)"
            prewarm_desc="no (default mode — root may contain stale files)"
        fi
    fi

    local hr="══════════════════════════════════════════════════════════"
    echo -e "${BOLD}${GREEN}${hr}${NC}"
    echo -e "  ${BOLD}ftp-camera ready${NC}"
    echo -e "${BOLD}${GREEN}──────────────────────────────────────────────────────────${NC}"
    printf '  %-13s %s\n' "Mode:"      "$mode_desc"
    if [ "$HOTSPOT_ACTIVE" = true ]; then
        local _own
        if [ "$HOTSPOT_OWNED_BY_US" = true ]; then
            _own="managed by ftp-camera, will close on exit"
        else
            _own="pre-existing, left alone on exit"
        fi
        printf '  %-13s on   (SSID: %s, IP: %s, dev: %s)\n' \
            "Hotspot:" "${HOTSPOT_SSID:--}" "$HOTSPOT_IP" "$HOTSPOT_DEV"
        printf '  %-13s      (%s)\n' "" "$_own"
    else
        printf '  %-13s off\n' "Hotspot:"
    fi
    if [ "$VIEWER_MODE" = true ]; then
        printf '  %-13s on  (class filter: %s)\n' "Viewer:"   "$VIEWER_CLASS"
        printf '  %-13s %s\n' "Watching:"  "$watch_path"
        printf '  %-13s %s\n' "Pre-warm:"  "$prewarm_desc"
    else
        printf '  %-13s off\n'                "Viewer:"
    fi
    if [ "$ASYNC_COPY_MODE" = true ]; then
        printf '  %-13s %s\n' "Rclone:"    "${RCLONE_REMOTE:-(unset)}"
        printf '  %-13s %s\n' "Mount:"     "${ASYNC_MOUNT_PATH:-(unset)}"
    fi
    printf '  %-13s %s\n' "Upload dir:"    "$UPLOAD_DIR"
    printf '  %-13s ftp://camera@%s/\n' "FTP URL:" "$LOCAL_IP"
    echo -e "${BOLD}${GREEN}${hr}${NC}"
    echo ""
    echo -e "  ${BOLD}Sony A7V camera settings${NC} (Menu → Network → FTP Transfer Func.):"
    echo -e "    Server:      ${CYAN}${LOCAL_IP}${NC}"
    echo -e "    Port:        ${CYAN}21${NC}"
    echo -e "    User:        ${CYAN}camera${NC}"
    echo -e "    Password:    ${CYAN}run 'ftp-camera --pass' to view${NC}"
    echo -e "    Passive:     ${CYAN}On${NC}"
    echo -e "    Destination: ${CYAN}/${NC}"
    echo ""
    echo -e "${YELLOW}Monitoring for uploads — press Ctrl+C to stop${NC}"
    echo ""
}

# Handle one inotify close_write event: sort the file and, in --async-copy,
# push the sorted result to the remote. Always returns 0 so a single bad
# file never kills the monitoring loop.
process_async_upload() {
    local filepath="$1"
    local basename
    basename=$(basename "$filepath")

    # Files inside our managed subtrees can't legitimately receive new
    # close_write events from the camera (vsftpd writes to the upload
    # root). Skip defensively in case future inotify behaviour or a
    # different uploader changes that assumption.
    local rel="${filepath#"$UPLOAD_DIR"/}"
    case "$rel" in
        "$PHOTO_DIR_NAME"/* | "$VIDEO_DIR_NAME"/*) return 0 ;;
    esac

    local ts
    ts=$(date '+%H:%M:%S')

    local sorted_path sort_rc=0
    sorted_path=$(sort_one_file "$filepath") || sort_rc=$?

    case $sort_rc in
        0)
            local rel_sorted="${sorted_path#"$UPLOAD_DIR"/}"
            echo -e "  [${CYAN}${ts}${NC}] ${GREEN}sort${NC}  ${basename}  → ${rel_sorted%/*}/"
            _async_stat_inc moved
            # Viewer hook — fires immediately after a successful sort,
            # before the optional mount copy. Network/remote status is
            # irrelevant to a local preview; latency to first pixel
            # shouldn't be gated on the cp into the rclone mount.
            if [ "$VIEWER_MODE" = true ] && viewer_class_matches "$sorted_path"; then
                display_in_viewer "$sorted_path"
            fi
            ;;
        1)
            echo -e "  [${CYAN}${ts}${NC}] ${YELLOW}skip${NC}  ${basename}  (unsupported type, left in place)"
            _async_stat_inc skipped
            return 0
            ;;
        2)
            echo -e "  [${CYAN}${ts}${NC}] ${YELLOW}skip${NC}  ${basename}  (no EXIF date, left in place)"
            _async_stat_inc skipped
            return 0
            ;;
        4)
            # File was already moved (camera retry, manual mv, etc.). Quiet
            # no-op — the handler that moved it accounted for it.
            return 0
            ;;
        *)
            echo -e "  [${CYAN}${ts}${NC}] ${RED}fail${NC}  ${basename}  (sort error, left in place)" >&2
            _async_stat_inc errored
            return 0
            ;;
    esac

    [ "$ASYNC_COPY_MODE" = true ] || return 0

    local copy_log copy_rc=0
    copy_log=$(copy_one_file_to_mount "$sorted_path" 2>&1) || copy_rc=$?
    local ts2
    ts2=$(date '+%H:%M:%S')

    if [ "$copy_rc" -eq 0 ]; then
        echo -e "  [${CYAN}${ts2}${NC}] ${GREEN}copy${NC}  ${basename}  → mount cache (VFS will upload)"
        _async_stat_inc copied
    else
        echo -e "  [${CYAN}${ts2}${NC}] ${RED}copy fail${NC}  ${basename}  (rc=${copy_rc}; sorted locally, rerun ftp-camera --push)" >&2
        if [ -n "$copy_log" ]; then
            printf '%s\n' "$copy_log" | sed 's/^/    /' >&2
        fi
        _async_stat_inc copy_errored
        if [ -n "$ASYNC_COPY_FAILED_FILE" ]; then
            echo "$sorted_path" >> "$ASYNC_COPY_FAILED_FILE"
        fi
    fi
    return 0
}

# Background loop driven by vsftpd's transfer log. We deliberately do NOT
# use inotify close_write here: close_write fires on every file close —
# including aborted/partial uploads where the camera disconnected mid-
# transfer. vsftpd only writes "OK UPLOAD" after a STOR completes cleanly,
# so triggering from the log guarantees we only sort and copy whole files.
# Failed transfers leave a partial file in the upload root for the user
# to inspect — never sorted, never sent to the remote.
async_monitor_loop() {
    sudo tail -F -n 0 --pid=$$ /var/log/vsftpd.log 2>/dev/null \
        | awk -F'"' '/OK UPLOAD: Client/ {print $4; fflush()}' \
        | while IFS= read -r fname; do
            [ -n "$fname" ] || continue
            # vsftpd logs paths relative to the camera user's chroot, which
            # is the upload dir. Prepend so the absolute path matches what
            # the rest of the script expects.
            process_async_upload "${UPLOAD_DIR}/${fname#/}"
          done
}

# ── Cleanup ────────────────────────────────────────────────────────────────────

cleanup() {
    # Re-entrancy guard: a second Ctrl+C arriving while cleanup is running
    # (e.g. during `systemctl stop`) would otherwise fire the EXIT trap
    # again, racing the systemctl/firewall-cmd ops below.
    if [ -n "${_CLEANED:-}" ]; then
        return 0
    fi
    _CLEANED=1

    echo ""
    echo -e "${BOLD}Stopping FTP server...${NC}"

    if [ -n "$MONITOR_PID" ] && ps -p "$MONITOR_PID" > /dev/null; then
        # In async mode MONITOR_PID is a subshell wrapping a tail|awk|while
        # pipeline; kill its children first so the upstream tail and awk
        # can't keep writing to a stats file we're about to read. In
        # default mode this is a no-op (inotifywait has no children).
        # `|| true`: pkill -P returns 1 when no children exist (the default-
        # mode case), which would trip `set -e` and abort cleanup before
        # vsftpd/firewall teardown — that's the bug that left the FTP
        # server running and the prompt showing "General error" after Ctrl+C.
        pkill -P "$MONITOR_PID" 2>/dev/null || true
        kill "$MONITOR_PID"
        # `|| true`: wait returns non-zero for signal-killed processes,
        # which is the normal path here. Required so the final
        # _async_stat_inc write lands before we awk the stats file below.
        wait "$MONITOR_PID" 2>/dev/null || true
    fi

    if [ -n "$VSFTPD_LOG_PID" ] && ps -p "$VSFTPD_LOG_PID" > /dev/null; then
        kill "$VSFTPD_LOG_PID"
    fi

    # Stop the viewer monitor (only set in default-mode + --view/--view-jpg).
    # The tail process inside has --pid=$$ so it would self-terminate at
    # script exit, but killing here closes the subshell cleanly so the
    # cleanup banner doesn't race with a late "viewer fired" log line.
    if [ -n "$VIEWER_MONITOR_PID" ] && ps -p "$VIEWER_MONITOR_PID" > /dev/null; then
        kill "$VIEWER_MONITOR_PID"
    fi

    if systemctl is-active --quiet vsftpd; then
        sudo systemctl stop vsftpd
    fi

    # Remove systemd override and runtime config (all in /run/ tmpfs)
    sudo rm -rf /run/systemd/system/vsftpd.service.d /run/vsftpd-camera.conf
    sudo systemctl daemon-reload

    # Remove firewall rules only if they were added (probe-then-act)
    if sudo firewall-cmd --query-service=ftp --quiet; then
        sudo firewall-cmd --remove-service=ftp --quiet
    fi
    if sudo firewall-cmd --query-port=30000-30100/tcp --quiet; then
        sudo firewall-cmd --remove-port=30000-30100/tcp --quiet
    fi

    # The hotspot zone is created on demand by firewalld+NetworkManager;
    # it disappears if the user closes the hotspot mid-session. Probe its
    # existence before trying to remove rules from it — `--query` against
    # a non-existent zone errors out, but the zone presence check is cheap.
    if sudo firewall-cmd --get-zones | grep -qw nm-shared; then
        if sudo firewall-cmd --zone=nm-shared --query-service=ftp --quiet; then
            sudo firewall-cmd --zone=nm-shared --remove-service=ftp --quiet
        fi
        if sudo firewall-cmd --zone=nm-shared --query-port=30000-30100/tcp --quiet; then
            sudo firewall-cmd --zone=nm-shared --remove-port=30000-30100/tcp --quiet
        fi
    fi

    # Hotspot teardown — only if WE activated it (--hotspot was passed
    # and the profile wasn't already up when we started). A pre-existing
    # user-toggled hotspot is left alone so their session continues.
    if [ "$HOTSPOT_OWNED_BY_US" = true ]; then
        if nmcli -t -f NAME connection show --active | grep -qxF "$HOTSPOT_CONNECTION"; then
            echo -e "${BOLD}Deactivating hotspot '${HOTSPOT_CONNECTION}'...${NC}"
            sudo nmcli connection down "$HOTSPOT_CONNECTION"
        fi
    fi

    echo -e "${GREEN}FTP server stopped.${NC}"
    echo ""

    # Summary: only files uploaded during this session (newer than start marker)
    if [ -d "$UPLOAD_DIR" ] && [ -f "$START_MARKER" ]; then
        local file_count total_bytes total_human
        file_count=$(find "$UPLOAD_DIR" -type f -newer "$START_MARKER" | wc -l)
        if [ "$file_count" -gt 0 ]; then
            total_bytes=$(find "$UPLOAD_DIR" -type f -newer "$START_MARKER" -printf '%s\n' \
                | awk '{s+=$1} END {print s+0}')
            total_human=$(numfmt --to=iec-i --suffix=B "$total_bytes")
            echo -e "${BOLD}Upload summary:${NC}"
            echo -e "  Files: ${CYAN}${file_count}${NC}"
            echo -e "  Total: ${CYAN}${total_human}${NC}"
            echo -e "  Path:  ${CYAN}${UPLOAD_DIR}${NC}"
            if [ "$file_count" -le 20 ]; then
                echo ""
                find "$UPLOAD_DIR" -type f -newer "$START_MARKER" -printf '  %h/%f  %s\n' \
                    | awk '{size=$NF; $NF=""; cmd="numfmt --to=iec-i --suffix=B " size; cmd | getline h; close(cmd); printf "%s %s\n", $0, h}'
            fi
        else
            echo -e "${BOLD}Upload summary:${NC}"
            echo "  (no files received)"
        fi
    fi
    rm -f "$START_MARKER"

    # Async-mode summary: counts come from the append-only stats file written
    # by process_async_upload. The monitor was killed above, so writes are
    # finished and the read is consistent.
    if [ "$ASYNC_MODE" = true ] && [ -n "$ASYNC_STATS_FILE" ] && [ -f "$ASYNC_STATS_FILE" ]; then
        local a_moved a_skipped a_errored a_copied a_copy_errored
        a_moved=$(awk '/^moved$/{c++} END{print c+0}' "$ASYNC_STATS_FILE")
        a_skipped=$(awk '/^skipped$/{c++} END{print c+0}' "$ASYNC_STATS_FILE")
        a_errored=$(awk '/^errored$/{c++} END{print c+0}' "$ASYNC_STATS_FILE")
        a_copied=$(awk '/^copied$/{c++} END{print c+0}' "$ASYNC_STATS_FILE")
        a_copy_errored=$(awk '/^copy_errored$/{c++} END{print c+0}' "$ASYNC_STATS_FILE")

        echo ""
        echo -e "${BOLD}Async summary:${NC}"
        echo -e "  Sorted: ${CYAN}${a_moved}${NC}  Skipped: ${CYAN}${a_skipped}${NC}  Sort errors: ${CYAN}${a_errored}${NC}"
        if [ "$ASYNC_COPY_MODE" = true ]; then
            echo -e "  Copied: ${CYAN}${a_copied}${NC}  Copy errors: ${CYAN}${a_copy_errored}${NC}"
            if [ "$a_copy_errored" -gt 0 ]; then
                echo -e "${YELLOW}Some files were sorted locally but did not reach the remote.${NC}"
                # Print the failed-copy list before deleting it so the user
                # can audit exactly what `ftp-camera --push` will re-ship.
                if [ -n "$ASYNC_COPY_FAILED_FILE" ] && [ -f "$ASYNC_COPY_FAILED_FILE" ]; then
                    while IFS= read -r f; do
                        echo -e "  ${RED}${f#"$UPLOAD_DIR"/}${NC}"
                    done < "$ASYNC_COPY_FAILED_FILE"
                fi
                echo -e "${YELLOW}Run:${NC} ${CYAN}ftp-camera --push${NC} ${YELLOW}to ship them.${NC}"
            fi

            # The rclone mount keeps draining VFS cache → remote after we
            # exit, so the upload is almost always still in flight here.
            # `rclone-tail` (deployed by play-rclone.yml) discovers the
            # mount automatically and formats queue/rate/ETA the same way
            # this toolchain uses elsewhere — much friendlier than raw
            # `rclone rc` JSON.
            local _remote_name="${RCLONE_REMOTE%%:*}"
            echo ""
            echo -e "${BOLD}Background uploads (rclone mount continues after exit):${NC}"
            if command -v rclone-tail > /dev/null; then
                # One-shot snapshot; `|| true`: rclone-tail exits non-zero
                # if no matching mount or RC unreachable, which we don't
                # want to abort the rest of cleanup.
                rclone-tail --once "$_remote_name" || true
                echo -e "  Watch live:            ${CYAN}rclone-tail ${_remote_name}${NC}"
            else
                echo -e "  ${YELLOW}rclone-tail not installed — re-run play-rclone.yml to get it${NC}"
            fi
            echo -e "  Verify/retry on remote:${CYAN} ftp-camera --push${NC} ${YELLOW}(--update skips files already uploaded)${NC}"
        fi
        rm -f "$ASYNC_STATS_FILE"
        [ -n "$ASYNC_COPY_FAILED_FILE" ] && rm -f "$ASYNC_COPY_FAILED_FILE"
    fi

    # Default mode runs sort_uploads here as the *only* sort pass, so it
    # must run unconditionally there. In async mode we deliberately skip
    # it: the OK UPLOAD log trigger already processed every clean upload,
    # and anything still in the upload root is a partial/failed transfer
    # we do NOT want to silently sort into the dated tree.
    # `|| true`: a single bad EXIF read shouldn't blow up the rest of
    # cleanup (firewall + systemd state still need to come down).
    if [ "$ASYNC_MODE" != true ]; then
        sort_uploads || true
    fi
}

trap cleanup EXIT
trap 'exit 0' INT TERM

# ── Password helper ───────────────────────────────────────────────────────────
if [ "$PASS_ONLY" = true ]; then
    # No FTP server — just print the vault-stored password and exit
    trap - EXIT INT TERM

    if [ ! -f "$CONFIG_FILE" ]; then
        echo "ERROR: $CONFIG_FILE not found — run play-ftp-camera.yml first" >&2
        exit 1
    fi

    # shellcheck source=/dev/null
    . "$CONFIG_FILE"

    if [ -z "${REPO_PATH:-}" ]; then
        echo "ERROR: REPO_PATH not set in $CONFIG_FILE" >&2
        exit 1
    fi
    if [ ! -x "$REPO_PATH/vault.bash" ]; then
        echo "ERROR: $REPO_PATH/vault.bash not found or not executable" >&2
        echo "  Repo may have moved — re-run play-ftp-camera.yml from current location" >&2
        exit 1
    fi

    exec "$REPO_PATH/vault.bash" get ftp_camera_password
fi

# ── Sort-only mode ────────────────────────────────────────────────────────────
if [ "$SORT_ONLY" = true ]; then
    # No FTP server — just sort existing files and exit
    trap - EXIT INT TERM
    sort_uploads
    exit 0
fi

# ── Push-only mode ────────────────────────────────────────────────────────────
if [ "$PUSH_ONLY" = true ]; then
    # No FTP server — just push sorted uploads to rclone remote and exit
    trap - EXIT INT TERM
    push_uploads
    exit 0
fi

# ── Copy-via-mount mode ──────────────────────────────────────────────────────
if [ "$COPY_ONLY" = true ]; then
    # No FTP server — copy to mount, wait for upload, verify on remote
    trap - EXIT INT TERM
    copy_to_mount
    exit 0
fi

# ── Prune-orphan-RAWs mode ───────────────────────────────────────────────────
if [ "$PRUNE_ONLY" = true ]; then
    # No FTP server — find RAWs whose JPG has been deleted, prompt, remove
    trap - EXIT INT TERM
    prune_orphan_raws
    exit 0
fi

# ── Main ───────────────────────────────────────────────────────────────────────

# Validate async-copy prerequisites BEFORE starting vsftpd so a misconfigured
# rclone setup doesn't expose the FTP port and then fail on the first upload.
# --async (sort only) has no extra prerequisites beyond the default path.
if [ "$ASYNC_COPY_MODE" = true ]; then
    load_rclone_config || exit 1

    # Resolve the local mount path the VFS exposes for this remote and
    # confirm it exists. Per-file copies land here, not on the remote URL,
    # so we don't depend on network reachability during FTP transfer.
    ASYNC_MOUNT_PATH=$(find_mount_path) || exit 1
    if [ ! -d "$ASYNC_MOUNT_PATH" ]; then
        echo "ERROR: rclone mount path not found: $ASYNC_MOUNT_PATH" >&2
        echo "  Is rclone-${RCLONE_REMOTE%%:*}.service running?" >&2
        exit 1
    fi
fi

if [ "$ASYNC_MODE" = true ]; then
    ASYNC_STATS_FILE=$(mktemp)
    if [ "$ASYNC_COPY_MODE" = true ]; then
        ASYNC_COPY_FAILED_FILE=$(mktemp)
    fi
fi

# Validate viewer prerequisites BEFORE starting vsftpd so a viewer-mode run
# with no geeqie or no display server doesn't expose the FTP port and then
# fail on the first upload. Same fail-fast pattern the async-copy block uses.
if [ "$VIEWER_MODE" = true ]; then
    if ! command -v geeqie > /dev/null; then
        echo "ERROR: --view / --view-jpg requires geeqie, not found in PATH" >&2
        echo "  Install via play-photography.yml, or drop the viewer flag." >&2
        exit 1
    fi
    if [ -z "${WAYLAND_DISPLAY:-}" ] && [ -z "${DISPLAY:-}" ]; then
        echo "ERROR: --view / --view-jpg has nothing to display — no GUI session" >&2
        echo "  Both WAYLAND_DISPLAY and DISPLAY are unset. You may be running" >&2
        echo "  over ssh without forwarding. Drop the viewer flag and re-run." >&2
        exit 1
    fi
fi

# Bring up the user-managed hotspot if requested via --hotspot. The
# named profile must already exist (typically created once via GNOME
# Settings → Wi-Fi → Hotspot, then optionally tuned by
# play-ftp-camera.yml for 40MHz / channel 6). We fail-fast if the
# profile is missing so the user doesn't accidentally expose FTP on
# the wrong network.
#
# HOTSPOT_OWNED_BY_US tracks whether we activated it. If the hotspot
# was already up when ftp-camera started (user toggled in GNOME), we
# use it but don't tear it down — their session continues unchanged
# on exit.
if [ "$HOTSPOT_FLAG" = true ]; then
    if [ -f "$CONFIG_FILE" ]; then
        # shellcheck source=/dev/null
        . "$CONFIG_FILE"
    fi
    HOTSPOT_CONNECTION="${HOTSPOT_CONNECTION:-Hotspot}"

    if ! command -v nmcli > /dev/null; then
        echo "ERROR: --hotspot needs nmcli (NetworkManager CLI)" >&2
        exit 1
    fi
    if ! nmcli -t -f NAME connection show | grep -qxF "$HOTSPOT_CONNECTION"; then
        echo "ERROR: NetworkManager connection '$HOTSPOT_CONNECTION' not found" >&2
        echo "  Create it once via GNOME Settings → Wi-Fi → Hotspot, then" >&2
        echo "  re-run play-ftp-camera.yml to tune it for 40MHz/channel 6." >&2
        echo "  (Override the connection name via ftp_camera_hotspot_connection" >&2
        echo "  in host_vars/localhost.yml if you've renamed it.)" >&2
        exit 1
    fi

    if nmcli -t -f NAME connection show --active | grep -qxF "$HOTSPOT_CONNECTION"; then
        echo -e "${YELLOW}Hotspot '${HOTSPOT_CONNECTION}' already active — using as-is, will not tear down on exit.${NC}"
    else
        echo -e "${BOLD}Activating hotspot '${HOTSPOT_CONNECTION}'...${NC}"
        sudo nmcli connection up "$HOTSPOT_CONNECTION"
        HOTSPOT_OWNED_BY_US=true
        # NM activation is async; give the AP a moment to bind and the
        # interface to acquire its 10.x.x.x address before detect_hotspot
        # runs. Without the sleep the first probe can miss the IP.
        sleep 2
    fi
fi

# Probe NetworkManager once for an active hotspot so subsequent
# get_local_ip / firewall / banner steps share consistent state.
detect_hotspot

LOCAL_IP=$(get_local_ip)

echo -e "${BOLD}Starting camera FTP server...${NC}"

# Runtime config: copy base config and add pasv_address so vsftpd advertises
# the correct LAN IP to the camera for passive mode data connections
sudo cp /etc/vsftpd/vsftpd.conf /run/vsftpd-camera.conf
echo "pasv_address=${LOCAL_IP}" | sudo tee -a /run/vsftpd-camera.conf > /dev/null

# Ensure vsftpd's privsep chroot dir exists (wiped on reboot — /run is tmpfs)
sudo mkdir -p /run/vsftpd/empty
sudo chmod 0755 /run/vsftpd /run/vsftpd/empty

# Systemd override: use runtime config instead of /etc/vsftpd/vsftpd.conf
sudo mkdir -p /run/systemd/system/vsftpd.service.d
printf '[Service]\nExecStart=\nExecStart=/usr/sbin/vsftpd %s\n' "/run/vsftpd-camera.conf" \
    | sudo tee /run/systemd/system/vsftpd.service.d/camera-ftp.conf > /dev/null
sudo systemctl daemon-reload

sudo systemctl start vsftpd
sudo firewall-cmd --add-service=ftp --quiet
sudo firewall-cmd --add-port=30000-30100/tcp --quiet

# When a NetworkManager shared connection (hotspot) is active, firewalld
# auto-assigns its interface to the `nm-shared` zone — a restrictive zone
# that allows DHCP and SSH but NOT FTP. Without these explicit
# nm-shared-zone additions, the camera's STOR connections from
# 10.x.x.x would be silently dropped despite the FTP server listening.
# The rules are runtime-only (no --permanent) so they evaporate on
# firewalld reload — exactly matching the runtime nature of the session.
if [ "$HOTSPOT_ACTIVE" = true ]; then
    sudo firewall-cmd --zone=nm-shared --add-service=ftp --quiet
    sudo firewall-cmd --zone=nm-shared --add-port=30000-30100/tcp --quiet
fi

echo ""
print_startup_banner

# ── Viewer pre-warm (async modes only) ───────────────────────────────────────
# Open geeqie against today's class subfolder before any uploads arrive so
# the first burst frame doesn't pay GTK init latency, AND so geeqie's
# arrow-key history list is already focused on the date directory new
# uploads will land in. Subsequent display_in_viewer calls route into the
# same window via geeqie's implicit single-instance.
#
# Skipped in default mode: the upload root may contain stale or mixed-class
# files from previous sessions; we don't want to surface those. Default
# mode cold-starts geeqie on the first matching arrival instead.
if [ "$VIEWER_MODE" = true ] && [ "$ASYNC_MODE" = true ]; then
    TODAY_VIEWER_DIR="$UPLOAD_DIR/$PHOTO_DIR_NAME/$(date +%Y/%m/%d)/$VIEWER_CLASS"
    sudo mkdir -p "$TODAY_VIEWER_DIR"
    display_in_viewer "$TODAY_VIEWER_DIR"
fi

# Stream vsftpd auth/connection events alongside upload notifications.
# --pid=$$ makes tail self-terminate when this script exits, so the
# subshell can't outlive us even if cleanup() misses it.
sudo tail -F -n 0 --pid=$$ /var/log/vsftpd.log 2>/dev/null \
    | awk -v r="$RED" -v g="$GREEN" -v c="$CYAN" -v y="$YELLOW" -v n="$NC" '
        /FAIL LOGIN/  { printf "  %s[fail]%s %s\n", r, n, $0; fflush(); next }
        /OK LOGIN/    { printf "  %s[auth]%s %s\n", g, n, $0; fflush(); next }
        /CONNECT/     { printf "  %s[conn]%s %s\n", c, n, $0; fflush(); next }
        /OK UPLOAD/   { next }   # already covered by inotifywait
        /FAIL UPLOAD/ { printf "  %s[fail]%s %s\n", r, n, $0; fflush(); next }
        { printf "  %s[ftp ]%s %s\n", y, n, $0; fflush() }
    ' &
VSFTPD_LOG_PID=$!

# Monitor upload directory. The default mode just pretty-prints events
# (the closing pass handles the actual sorting). Async modes route every
# close_write through process_async_upload, which sorts and optionally
# pushes to the remote in real time. Both run in background so the INT
# trap fires correctly on Ctrl+C.
if [ "$ASYNC_MODE" = true ]; then
    async_monitor_loop &
    MONITOR_PID=$!
    # In async modes the viewer hook lives INSIDE process_async_upload
    # (fires after each successful sort, gated on VIEWER_CLASS). No
    # separate monitor process needed here.
else
    inotifywait -m -r -q \
        -e close_write,moved_to \
        --format "  [%T] %e  %w%f" \
        --timefmt "%H:%M:%S" \
        "$UPLOAD_DIR" &
    MONITOR_PID=$!
    # Default mode: there's no process_async_upload codepath to hook
    # into, so the viewer needs its own log-tail loop alongside
    # inotifywait. inotify handles the human-readable event stream;
    # viewer_monitor_loop drives geeqie on completed (OK UPLOAD) arrivals.
    if [ "$VIEWER_MODE" = true ]; then
        viewer_monitor_loop &
        VIEWER_MONITOR_PID=$!
    fi
fi

wait "$MONITOR_PID"
