#!/bin/bash
# rclone-tail - monitor live rclone mount activity (queue, bandwidth, ETA)
#
# Usage: rclone-tail [--interval N] [--once] [MOUNT_NAME]
#   MOUNT_NAME      monitor only this remote (e.g. 'lts-photo'); default: all
#   --interval, -i  poll interval in seconds (default: 5)
#   --once, -o      print one snapshot and exit (no streaming)
#   --help, -h      show this help
#
# Discovers running rclone mounts via findmnt and queries each mount's --rc
# endpoint for vfs/stats (queue depth) and core/stats (bytes, transfers,
# eta). Shows queue depth, in-flight uploads, instantaneous transfer rate,
# and ETA per mount per tick. Mounts started without --rc are listed as
# '(no --rc)' — they cannot be queried.
#
# Idle mounts (no queue, no in-flight, no bytes moving) collapse to 'idle'
# so active mounts stand out. Pipe through `grep -v idle` to see only
# transferring mounts.

set -euo pipefail

INTERVAL=5
ONCE=false
FILTER=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -i|--interval)
            INTERVAL="${2:-}"
            shift 2
            ;;
        -o|--once)
            ONCE=true
            shift
            ;;
        -h|--help)
            sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        -*)
            echo "ERROR: unknown option: $1" >&2
            exit 2
            ;;
        *)
            if [[ -n "$FILTER" ]]; then
                echo "ERROR: only one mount name can be specified" >&2
                exit 2
            fi
            FILTER="$1"
            shift
            ;;
    esac
done

if ! [[ "$INTERVAL" =~ ^[1-9][0-9]*$ ]]; then
    echo "ERROR: --interval must be a positive integer (got: '$INTERVAL')" >&2
    exit 2
fi

if ! command -v rclone > /dev/null; then
    echo "ERROR: rclone not found — run play-rclone.yml first" >&2
    exit 1
fi

if [ -t 1 ]; then
    BOLD='\033[1m'
    DIM='\033[2m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    CYAN='\033[0;36m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    BOLD=''; DIM=''; GREEN=''; YELLOW=''; CYAN=''; RED=''; NC=''
fi

# Emit one line per discovered rclone mount: NAME|RC_ADDR|REMOTE|MOUNTPOINT
# RC_ADDR is empty when the mount was started without --rc.
discover_mounts() {
    local source target name pid cmdline rc_addr
    findmnt -n -o SOURCE,TARGET -t fuse.rclone 2>/dev/null | while read -r source target; do
        name="${source%%:*}"
        if [[ -n "$FILTER" && "$name" != "$FILTER" ]]; then
            continue
        fi

        rc_addr=""
        # Find the rclone PID whose cmdline ends with this mount target.
        # `pgrep -f 'rclone mount'` filters down the candidate set; we then
        # match the mountpoint as a literal token to avoid regex pitfalls
        # with paths.
        for pid in $(pgrep -f 'rclone mount' 2>/dev/null || true); do
            if ! cmdline=$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null); then
                continue
            fi
            case "$cmdline" in
                *" $target "*|*" $target")
                    rc_addr=$(grep -oE -- '--rc-addr=[^ ]+' <<<"$cmdline" \
                        | head -n1 | cut -d= -f2)
                    break
                    ;;
            esac
        done

        echo "${name}|${rc_addr}|${source}|${target}"
    done
}

# Args: rc_addr
# Stdout (success): OK|in_progress|queued|errored|bytes|total_bytes|done|total|eta
# Stdout (failure): ERR|<reason>
query_stats() {
    local rc_addr="$1"
    local vfs_json core_json
    if ! vfs_json=$(rclone rc --url="http://${rc_addr}" vfs/stats 2>/dev/null); then
        echo "ERR|rc unreachable"
        return
    fi
    if ! core_json=$(rclone rc --url="http://${rc_addr}" core/stats 2>/dev/null); then
        echo "ERR|rc unreachable"
        return
    fi
    if ! python3 - "$vfs_json" "$core_json" <<'PY' 2>/dev/null
import json, sys
vfs = json.loads(sys.argv[1])
core = json.loads(sys.argv[2])
dc = (vfs.get("diskCache") or {})
in_progress = int(dc.get("uploadsInProgress", 0))
queued = int(dc.get("uploadsQueued", 0))
errored = int(dc.get("erroredFiles", 0))
bytes_done = int(core.get("bytes", 0) or 0)
total_bytes = int(core.get("totalBytes", 0) or 0)
done_count = int(core.get("transfers", 0) or 0)
total_count = int(core.get("totalTransfers", 0) or 0)
eta = core.get("eta")
eta_s = "" if eta is None else str(int(eta))
print(f"OK|{in_progress}|{queued}|{errored}|{bytes_done}|{total_bytes}|{done_count}|{total_count}|{eta_s}")
PY
    then
        echo "ERR|parse failed"
    fi
}

# Per-mount byte/time tracking for instantaneous rate calculation
declare -A PREV_BYTES
declare -A PREV_TIME

format_duration() {
    local s="$1"
    if [[ -z "$s" || "$s" == "0" ]]; then
        echo "—"
        return
    fi
    printf '%dm%02ds' $((s / 60)) $((s % 60))
}

render_tick() {
    local mounts ts
    mounts=$(discover_mounts)

    if [[ -z "$mounts" ]]; then
        if [[ -n "$FILTER" ]]; then
            echo -e "${YELLOW}No rclone mount matching '${FILTER}' found.${NC}"
        else
            echo -e "${YELLOW}No rclone mounts found.${NC}"
        fi
        return 1
    fi

    ts=$(date +'%H:%M:%S')
    echo -e "${BOLD}=== ${ts} ===${NC}"

    local name rc_addr remote target
    while IFS='|' read -r name rc_addr remote target; do
        if [[ -z "$rc_addr" ]]; then
            echo -e "  ${CYAN}${name}${NC}  ${DIM}(no --rc; cannot query)${NC}"
            continue
        fi

        local result status
        result=$(query_stats "$rc_addr")
        status="${result%%|*}"

        if [[ "$status" == "ERR" ]]; then
            echo -e "  ${CYAN}${name}${NC}  ${RED}error: ${result#*|}${NC}"
            continue
        fi

        local in_progress queued errored bytes_done total_bytes done_count total_count eta
        IFS='|' read -r _ in_progress queued errored bytes_done total_bytes done_count total_count eta <<<"$result"

        local now prev_b prev_t delta_t rate_bps
        now=$SECONDS
        prev_b="${PREV_BYTES[$name]:-0}"
        prev_t="${PREV_TIME[$name]:-$now}"
        delta_t=$(( now - prev_t ))
        rate_bps=0
        if [[ "$delta_t" -gt 0 && "$bytes_done" -ge "$prev_b" ]]; then
            rate_bps=$(( (bytes_done - prev_b) / delta_t ))
        fi
        PREV_BYTES["$name"]=$bytes_done
        PREV_TIME["$name"]=$now

        if [[ "$in_progress" -eq 0 && "$queued" -eq 0 && "$rate_bps" -eq 0 ]]; then
            local err_note=""
            if [[ "$errored" -gt 0 ]]; then
                err_note=" ${RED}(${errored} error(s))${NC}"
            fi
            echo -e "  ${CYAN}${name}${NC}  ${DIM}idle${NC}${err_note}"
            continue
        fi

        local rate_h bytes_h total_bytes_h eta_h
        rate_h=$(numfmt --to=iec --suffix=B/s "$rate_bps" 2>/dev/null || echo "?")
        bytes_h=$(numfmt --to=iec --suffix=B "$bytes_done" 2>/dev/null || echo "?")
        total_bytes_h=$(numfmt --to=iec --suffix=B "$total_bytes" 2>/dev/null || echo "?")
        eta_h=$(format_duration "$eta")

        echo -e "  ${CYAN}${name}${NC}  queued: ${CYAN}${queued}${NC} · active: ${CYAN}${in_progress}${NC} · done: ${CYAN}${done_count}/${total_count}${NC} (${bytes_h}/${total_bytes_h}) · ${GREEN}${rate_h}${NC} · ETA ${YELLOW}${eta_h}${NC}"
    done <<<"$mounts"
}

trap 'echo ""; exit 0' INT TERM

if [[ "$ONCE" == true ]]; then
    render_tick
    exit 0
fi

while true; do
    render_tick || exit 1
    sleep "$INTERVAL"
done
