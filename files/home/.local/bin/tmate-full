#!/usr/bin/env bash
set -e

# tmate-full — start tmate and show ALL connection URLs (read-write + read-only)
# Deployed by: playbooks/imports/optional/common/play-collaboration.yml
#
# WARNING: read-write URLs give full shell access to your session.
# Only share read-write URLs with people you fully trust.
# Prefer tmate-share for read-only sharing.

tmate -F &
TMATE_PID=$!

# Wait for tmate to establish the session and generate URLs
for _ in $(seq 1 30); do
    if tmate show-messages 2>/dev/null | grep -q "read only"; then
        break
    fi
    sleep 0.5
done

echo ""
echo "=== All Session URLs ==="
echo ""
tmate show-messages 2>/dev/null
echo ""
echo "WARNING: read-write URLs give full shell access!"
echo ""

# Bring tmate back to foreground
wait "$TMATE_PID"
