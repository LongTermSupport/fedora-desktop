#!/usr/bin/env bash
set -e

# lan-scan — discover devices on the local network
# Deployed by: playbooks/imports/optional/common/play-network-tools.yml

# ── QNAP MAC OUI prefixes ─────────────────────────────────────────────────────
# @see https://maclookup.app/vendors/qnap-systems-inc
QNAP_OUIS=(
    "00:08:9b"
    "24:5e:be"
)

# ── Colours ────────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ── Helpers ────────────────────────────────────────────────────────────────────

get_default_interface() {
    ip -4 route show default | awk '{print $5; exit}'
}

get_subnet() {
    local iface
    iface=$(get_default_interface)
    if [ -z "$iface" ]; then
        echo "ERROR: No default network interface found" >&2
        exit 1
    fi
    ip -4 addr show dev "$iface" | awk '/inet / {print $2; exit}'
}

is_qnap_mac() {
    local mac="${1,,}"  # lowercase
    local prefix="${mac:0:8}"
    for oui in "${QNAP_OUIS[@]}"; do
        if [ "$prefix" = "$oui" ]; then
            return 0
        fi
    done
    return 1
}

resolve_hostname() {
    local ip="$1"
    local name=""
    # Try reverse DNS first
    name=$(host "$ip" 2>/dev/null | awk '/domain name pointer/ {print $NF; exit}' | sed 's/\.$//')
    # Fall back to mDNS (avahi) if available and DNS returned nothing
    if [ -z "$name" ] && command -v avahi-resolve-address &>/dev/null; then
        name=$(avahi-resolve-address "$ip" 2>/dev/null | awk '{print $2}')
    fi
    echo "${name:--}"
}

require_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo "This command requires root privileges for raw packet access." >&2
        echo "Re-running with sudo..." >&2
        exec sudo "$0" "$@"
    fi
}

# ── Commands ───────────────────────────────────────────────────────────────────

cmd_scan() {
    require_root "$@"
    local subnet
    subnet=$(get_subnet)
    local iface
    iface=$(get_default_interface)

    echo -e "${BOLD}Scanning ${CYAN}${subnet}${NC}${BOLD} on ${iface}...${NC}"
    echo ""

    # arp-scan is fastest for L2 discovery — shows MAC vendor strings
    # Run twice to improve reliability (devices don't always respond to every probe)
    local tmpraw tmpdedup
    tmpraw=$(mktemp)
    tmpdedup=$(mktemp)
    arp-scan --localnet --interface="$iface" --plain 2>/dev/null >> "$tmpraw"
    arp-scan --localnet --interface="$iface" --plain 2>/dev/null >> "$tmpraw"

    # Deduplicate by IP (keep first MAC/vendor seen), then sort by IP numerically
    awk -F'\t' '!seen[$1]++ { print }' "$tmpraw" \
        | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n > "$tmpdedup"

    # Column headers
    printf "${BOLD}%-18s  %-20s  %-30s  %s${NC}\n" "IP Address" "MAC Address" "Hostname" "Vendor / Info"
    printf "%-18s  %-20s  %-30s  %s\n" "──────────────────" "────────────────────" "──────────────────────────────" "────────────────────────────"

    local qnap_found=()
    while IFS=$'\t' read -r ip mac vendor; do
        [ -z "$ip" ] && continue
        local hostname
        hostname=$(resolve_hostname "$ip")
        if is_qnap_mac "$mac"; then
            printf "${GREEN}${BOLD}%-18s  %-20s  %-30s  %s  ← QNAP${NC}\n" "$ip" "$mac" "$hostname" "$vendor"
            qnap_found+=("$ip")
        else
            printf "%-18s  %-20s  %-30s  %s\n" "$ip" "$mac" "$hostname" "$vendor"
        fi
    done < "$tmpdedup"

    rm -f "$tmpraw" "$tmpdedup"
    echo ""

    if [ ${#qnap_found[@]} -gt 0 ]; then
        echo -e "${GREEN}${BOLD}Found ${#qnap_found[@]} QNAP device(s):${NC}"
        for ip in "${qnap_found[@]}"; do
            echo -e "  ${GREEN}${ip}${NC}  →  https://${ip}:8080  or  https://${ip}:443"
        done
    else
        echo -e "${YELLOW}No QNAP devices found by MAC address.${NC}"
        echo "Try:  lan-scan find-nas   (port-based NAS discovery)"
    fi
}

cmd_find_nas() {
    require_root "$@"
    local subnet
    subnet=$(get_subnet)

    echo -e "${BOLD}Scanning ${CYAN}${subnet}${NC}${BOLD} for NAS devices (ports 443, 8080, 8443, 5000, 5001, 22)...${NC}"
    echo "This may take 15-30 seconds."
    echo ""

    # Scan common NAS web UI ports across the subnet
    # 443/8080  — QNAP QTS web UI
    # 8443      — UniFi / other management UIs
    # 5000/5001 — Synology DSM
    # 22        — SSH (most NAS devices)
    # 139/445   — SMB file sharing
    local tmpfile
    tmpfile=$(mktemp)
    nmap -sS -p 443,8080,8443,5000,5001,22,139,445 \
         --open --min-rate 500 -T4 \
         "$subnet" -oG "$tmpfile" 2>/dev/null

    echo -e "${BOLD}Hosts with NAS-like open ports:${NC}"
    echo ""
    printf "${BOLD}%-18s  %-50s  %s${NC}\n" "IP Address" "Open Ports" "Hostname"
    printf "%-18s  %-50s  %s\n" "──────────────────" "──────────────────────────────────────────────────" "────────────────────────"

    grep "^Host:" "$tmpfile" | grep -v "Status: Down" | while read -r line; do
        local ip ports hostname
        ip=$(echo "$line" | awk '{print $2}')
        ports=$(echo "$line" | grep -oP 'Ports: \K[^#]+' | sed 's|/open/[^,]*||g; s/, / /g; s|/open[^ ]*||g')
        hostname=$(host "$ip" 2>/dev/null | awk '/domain name pointer/ {print $NF}' | sed 's/\.$//')
        [ -z "$hostname" ] && hostname="-"

        # Highlight if QNAP-likely ports (8080+443 both open)
        if echo "$ports" | grep -q "8080" && echo "$ports" | grep -q "443"; then
            printf "${GREEN}${BOLD}%-18s${NC}  %-50s  %s  ${GREEN}← likely NAS${NC}\n" "$ip" "$ports" "$hostname"
        else
            printf "%-18s  %-50s  %s\n" "$ip" "$ports" "$hostname"
        fi
    done

    rm -f "$tmpfile"
    echo ""
    echo "Tip: Open https://<ip>:8080 in a browser to check QNAP web UI."
}

cmd_ports() {
    local target="$1"
    if [ -z "$target" ]; then
        echo "Usage: lan-scan ports <ip-address>" >&2
        exit 1
    fi

    echo -e "${BOLD}Scanning all common ports on ${CYAN}${target}${NC}${BOLD}...${NC}"
    echo ""
    nmap -sT -p 1-10000 --open -T4 "$target" 2>/dev/null | grep -E "^[0-9]+/|^Nmap|^Host|PORT"
}

cmd_watch() {
    require_root "$@"
    local subnet
    subnet=$(get_subnet)
    local iface
    iface=$(get_default_interface)

    echo -e "${BOLD}Watching ${CYAN}${subnet}${NC}${BOLD} for new devices (ARP monitor on ${iface})...${NC}"
    echo "Press Ctrl+C to stop."
    echo ""
    arp-scan --localnet --interface="$iface" --retry=0 --plain --quiet 2>/dev/null | while IFS=$'\t' read -r ip mac vendor; do
        local tag=""
        if is_qnap_mac "$mac"; then
            tag=" ${GREEN}${BOLD}← QNAP${NC}"
        fi
        printf "[%s]  %-18s  %-20s  %s%b\n" "$(date +%H:%M:%S)" "$ip" "$mac" "$vendor" "$tag"
    done
}

# ── Main ───────────────────────────────────────────────────────────────────────

usage() {
    cat <<'EOF'
lan-scan — discover devices on the local network

Usage:
  lan-scan              Quick ARP scan, highlights QNAP devices
  lan-scan find-nas     Port-based scan for NAS devices (QNAP, Synology)
  lan-scan ports <ip>   Detailed port scan of a specific host
  lan-scan watch        Live ARP monitor — shows devices as they appear

Examples:
  lan-scan                       # Find all devices, highlight QNAPs
  lan-scan find-nas              # Find NAS devices by open ports
  lan-scan ports <ip-address>    # What ports are open on this host?
EOF
}

case "${1:-scan}" in
    scan|"")
        shift 2>/dev/null || true
        cmd_scan "$@"
        ;;
    find-nas)
        shift
        cmd_find_nas "$@"
        ;;
    ports)
        shift
        cmd_ports "$@"
        ;;
    watch)
        shift
        cmd_watch "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        echo "Unknown command: $1" >&2
        usage >&2
        exit 1
        ;;
esac
